DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5441/dotmac_mkt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dotmac_mkt

REDIS_PASSWORD=redis
