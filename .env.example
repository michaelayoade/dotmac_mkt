CELERY_RESULT_BACKEND=redis://:redis@localhost:6379/1
CELERY_TIMEZONE=UTC

JWT_SECRET=openbao://secret/data/dotmac_mkt#jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
TOTP_ISSUER=dotmac_mkt
